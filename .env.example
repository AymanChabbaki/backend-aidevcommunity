# Database (Prisma)
DATABASE_URL="mysql://DB_USER:DB_PASS@DB_HOST:3306/DB_NAME"

# Firebase Admin: either a path to a service account JSON file
# or the base64-encoded JSON string. Provide one of these.
FIREBASE_SERVICE_ACCOUNT_PATH="/path/to/serviceAccount.json"
#FIREBASE_SERVICE_ACCOUNT_BASE64="{...base64...}"

# Cloudinary (used for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Server
PORT=5000

# API URL (used by frontend examples)
VITE_API_URL=http://localhost:5000/api
